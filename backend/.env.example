# Copy to `backend/.env` (this file is git-ignored).
# Values here are placeholders. Do NOT commit real keys.

# ── Django (Production) ──
# Set `DJANGO_ENV=production` in real deployments.
DJANGO_ENV=development
DJANGO_DEBUG=true
DJANGO_SECRET_KEY=change-me-to-a-long-random-string
DJANGO_ALLOWED_HOSTS=localhost,127.0.0.1

# Use Postgres in production (psycopg2-binary is included in requirements.txt).
# Example:
# DATABASE_URL=postgresql://USER:PASSWORD@HOST:5432/DBNAME
# DATABASE_URL=sqlite:////absolute/path/to/db.sqlite3

# CORS/CSRF (lock these down in production)
# CORS_ALLOW_ALL_ORIGINS=false
# CORS_ALLOWED_ORIGINS=https://your-frontend.example
# CSRF_TRUSTED_ORIGINS=https://your-frontend.example

# Security toggles (recommended for production behind HTTPS)
# SECURE_SSL_REDIRECT=true
# SESSION_COOKIE_SECURE=true
# CSRF_COOKIE_SECURE=true
# SECURE_HSTS_SECONDS=3600
# SECURE_HSTS_INCLUDE_SUBDOMAINS=true
# SECURE_HSTS_PRELOAD=false
# USE_X_FORWARDED_PROTO=true

# Logistics webhook (optional; if set, requests must include header `X-Webhook-Secret`)
LOGISTICS_WEBHOOK_SECRET=change-me

# ── Pathao (Sandbox) ──
PATHAO_SANDBOX_BASE_URL=https://courier-api-sandbox.pathao.com
PATHAO_SANDBOX_CLIENT_ID=your_sandbox_client_id
PATHAO_SANDBOX_CLIENT_SECRET=your_sandbox_client_secret
PATHAO_SANDBOX_USERNAME=your_sandbox_username
PATHAO_SANDBOX_PASSWORD=your_sandbox_password

# ── Pathao (Production) ──
PATHAO_PROD_BASE_URL=https://api-hermes.pathao.com
PATHAO_PROD_CLIENT_ID=your_prod_client_id
PATHAO_PROD_CLIENT_SECRET=your_prod_client_secret
PATHAO_PROD_USERNAME=your_prod_username
PATHAO_PROD_PASSWORD=your_prod_password

# ── Steadfast (Packzy) ──
STEADFAST_BASE_URL=https://portal.packzy.com/api/v1
STEADFAST_API_KEY=your_api_key
STEADFAST_API_SECRET=your_api_secret

# ── RedX ──
# Endpoints vary by merchant integration. You can override paths as needed.
REDX_BASE_URL=https://example.redx.base.url
REDX_API_KEY=your_api_key
REDX_CREATE_PARCEL_PATH=/api/v1/parcels
REDX_PARCEL_STATUS_PATH=/api/v1/parcels/{reference}
# REDX_AREAS_PATH=/api/v1/areas
